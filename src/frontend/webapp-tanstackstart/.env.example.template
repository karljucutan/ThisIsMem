# =========================================================================
# SERVER-ONLY VARIABLES (Strictly Private - No VITE_ Prefix)
# These will NEVER leak to the browser. Access via: process.env.VAR_NAME
# =========================================================================

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/my_db?schema=public"

# Authentication Secrets (e.g., Auth.js / Better Auth)
AUTH_SECRET="your-super-long-random-32-character-secret-key"
AUTH_URL="http://localhost:3000"

# Third-Party Private API Keys
STRIPE_SECRET_KEY="sk_test_..."
RESEND_API_KEY="re_..."
OPENAI_API_KEY="sk-proj-..."


# =========================================================================
# CLIENT-SAFE VARIABLES (Public - Must Start With VITE_)
# These ARE bundled into the browser code. Access via: import.meta.env.VITE_VAR_NAME
# =========================================================================

# Public App Routing & API Base Paths
VITE_APP_URL="http://localhost:3000"
VITE_PUBLIC_API_URL="https://myservice.com"

# Third-Party Public Keys
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
VITE_POSTHOG_KEY="phc_..."
